    {
      "name": "Upstream API (WP v2)",
      "item": [
        {
          "name": "WP: Listar productos - /product?_embed=1&per_page=100",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{wpBaseUrl}}/product?_embed=1&per_page=100",
              "host": [ "{{wpBaseUrl}}" ],
              "path": [ "product" ],
              "query": [
                { "key": "_embed", "value": "1" },
                { "key": "per_page", "value": "100" }
              ]
            }
          }
        },
        {
          "name": "WP: Producto por ID - /product/{{productId}}?_embed=1",
