{
  "info": {
    "name": "SJ - Endpoints usados (Proxy + Upstream)",
    "description": "Colección con los endpoints usados por el proyecto.\n\nIncluye:\n- Proxy PHP del proyecto (/api/*.php)\n- Endpoints upstream del API (/wp-json/wp/v2)\n\nUsa el environment \"SJ - Local\" para variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Proxy API (PHP)",
      "item": [
        {
          "name": "Listar productos (proxy) - /api/wp-products.php",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{apiBaseUrl}}/api/wp-products.php",
              "host": [ "{{apiBaseUrl}}" ],
              "path": [ "api", "wp-products.php" ]
            }
          }
        },
        {
          "name": "Producto por ID (proxy) - /api/wp-product.php?id={{productId}}",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{apiBaseUrl}}/api/wp-product.php?id={{productId}}",
              "host": [ "{{apiBaseUrl}}" ],
              "path": [ "api", "wp-product.php" ],
              "query": [
                { "key": "id", "value": "{{productId}}" }
              ]
            }
          }
        },
        {
          "name": "Producto por slug (proxy) - /api/wp-product.php?slug={{productSlug}}",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
