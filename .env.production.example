# Renombra a .env.production y usa con Docker Compose (servicio php).
# En VPS con PHP-FPM + systemd, define las mismas variables en el pool o en el entorno del servicio.

WP_API_BASE="https://www.gb-vnzl.com/wp-json/wp/v2"
# Opcional: si no usas WP_API_BASE ni endpoints específicos, define la base por defecto.
# WP_API_DEFAULT_BASE="https://tu-wordpress.com/wp-json/wp/v2"
# Solo hosts (sin https://); incluye el host de WP_API_BASE
WP_PRODUCTS_ALLOWED_HOSTS="gb-vnzl.com,www.gb-vnzl.com"

WP_PRODUCTS_TIMEOUT=5
WP_PRODUCTS_MAX_BYTES=8000000
WP_PRODUCTS_PER_PAGE=50
WP_PRODUCTS_CACHE_TTL=60

# Origen público de tu web (sin barra final). Misma URL que abren los usuarios.
WP_API_CORS_ORIGINS="https://sj-seven-murex.vercel.app"

# Puerto publicado por nginx en docker-compose (opcional, default 8080)
# HTTP_PORT=8080
