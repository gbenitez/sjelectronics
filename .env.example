# Base única del REST de WordPress (recomendado). Ajustá esta URL para local o producción.
# Si no la defines (ni WP_*_ENDPOINT ni WP_API_DEFAULT_BASE), el sitio usa datos locales de respaldo.
WP_API_BASE="http://localhost/wordpress/wp-json/wp/v2"

# Opcional: solo si no usas WP_API_BASE; misma forma …/wp-json/wp/v2
# WP_API_DEFAULT_BASE="https://tu-wordpress.com/wp-json/wp/v2"

# Si prefieres sobrescribir endpoints específicos, puedes usar:
# WP_PRODUCTS_ENDPOINT="http://localhost/wordpress/wp-json/wp/v2/product/"
# WP_POSTS_ENDPOINT="http://localhost/wordpress/wp-json/wp/v2/posts/"

# Seguridad / hardening (incluye el host o IP de WP_API_BASE, p. ej. 18.231.113.211)
WP_PRODUCTS_ALLOWED_HOSTS="localhost,127.0.0.1,mi-dominio.com"

# HTTPS: si conectás por IP y el cert es solo para un dominio, falla la verificación SSL.
# Opciones: WP_TLS_INSECURE=1 (solo dev), o usar https://dominio-real/… en WP_API_BASE, o HTTP sin TLS.
# WP_TLS_INSECURE=1

# Debug: cabeceras X-SJ-* y meta.debugUpstream (mismo efecto que ?debug=1 en la URL del proxy).
# WP_API_DEBUG=1

# Performance (listado productos: si ves "Respuesta demasiado grande", subí MAX_BYTES o bajá PER_PAGE)
WP_PRODUCTS_TIMEOUT=5
WP_PRODUCTS_MAX_BYTES=8000000
WP_PRODUCTS_PER_PAGE=50
WP_PRODUCTS_CACHE_TTL=60

# CORS (puerto de Vite en vite.config.js suele ser 3000)
WP_API_CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# npm run dev:full (scripts/dev-with-php.mjs) inyecta este .env al proceso PHP para que getenv(WP_*) funcione.

# --- Producción ---
# 1) npm run build:deploy  → dist/ con front + api/*.php
# 2) VPS: Nginx + PHP-FPM → ver deploy/nginx.example.conf (variables WP_* en el pool FPM o systemd)
# 3) Docker: cp .env.production.example .env.production, luego:
#    npm run build:deploy && docker compose --env-file .env.production up -d --build

